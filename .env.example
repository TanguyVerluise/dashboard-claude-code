# Neon Postgres (Vercel Marketplace) — chaîne de connexion poolée
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Clé officielle MemberPress : envoyée par MemberPress dans le header
# `memberpress-webhook-key`. À copier depuis MemberPress > Developers > Webhooks.
MEMBERPRESS_WEBHOOK_KEY=copie-la-cle-depuis-memberpress

# Secret optionnel pour les tests manuels (?token=... ou header x-webhook-secret)
WEBHOOK_SECRET=change-me-long-random-string

# Signing secret du webhook Tally (à coller dans Tally > Integrations > Webhooks)
TALLY_SIGNING_SECRET=genere-un-secret
